---
interface Props {
  id?: string;
  gray?: boolean;
  class?: string;
}

const { id, gray = false, class: className = '' } = Astro.props;
const bg = gray ? 'bg-light-gray border-y border-neutral-gray' : '';
---

<section id={id} class:list={['py-16 max-sm:py-11', bg, className]}>
    <div class="max-w-[1200px] mx-auto px-5 max-sm:px-4">
        <slot />
    </div>
</section>
