---
interface Props {
  question: string;
  answer: string;
  index?: number;
}

const { question, answer, index = 0 } = Astro.props;
---

<details
  class="group faq-reveal bg-bg-base border border-neutral-gray rounded-lg shadow-[0_2px_4px_rgba(0,0,0,0.05)] transition-all duration-300 hover:border-accent-red hover:shadow-[0_4px_16px_rgba(0,0,0,0.08)] open:border-accent-red/40 open:shadow-[0_4px_16px_rgba(196,30,58,0.08)]"
  style={`--reveal-delay: ${index * 80}ms`}
>
    <summary class="flex items-center justify-between gap-4 px-5 py-4 cursor-pointer list-none select-none focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-red">
        <span class="font-sans text-[0.85rem] max-sm:text-[0.8rem] font-semibold text-text-primary leading-snug">{question}</span>
        <span class="shrink-0 w-6 h-6 rounded-full border border-border-mid flex items-center justify-center transition-all duration-300 group-hover:border-accent-red group-open:bg-accent-red group-open:border-accent-red group-open:rotate-45" aria-hidden="true">
            <svg class="w-3 h-3 text-text-muted group-open:text-white transition-colors duration-300" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="6" y1="1" x2="6" y2="11" />
                <line x1="1" y1="6" x2="11" y2="6" />
            </svg>
        </span>
    </summary>
    <div class="faq-answer overflow-hidden">
        <div class="px-5 pb-5 pt-0">
            <div class="h-px bg-border-dark mb-4"></div>
            <p class="text-text-secondary text-[0.85rem] max-sm:text-[0.8rem] leading-relaxed" set:html={answer}></p>
        </div>
    </div>
</details>
