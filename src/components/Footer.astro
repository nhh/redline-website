---
import Logo from './Logo.astro';

interface FooterLink {
  href: string;
  label: string;
}

interface FooterColumn {
  title: string;
  links: FooterLink[];
}

const columns: FooterColumn[] = [
  {
    title: 'Leistungen',
    links: [
      { href: '#leistungen', label: 'Landing Pages' },
      { href: '#leistungen', label: 'Unternehmenswebsites' },
      { href: '#leistungen', label: 'Web-Applikationen' },
      { href: '#leistungen', label: 'Relaunch & Optimierung' },
    ],
  },
  {
    title: 'Unternehmen',
    links: [
      { href: '#ansatz', label: 'Unser Ansatz' },
      { href: '#prozess', label: 'Prozess' },
      { href: '#referenzen', label: 'Referenzen' },
      { href: '#faq', label: 'FAQ' },
      { href: '/brand', label: 'Brand Guide' },
    ],
  },
  {
    title: 'Rechtliches',
    links: [
      { href: '#', label: 'Impressum' },
      { href: '#', label: 'Datenschutz' },
      { href: '#', label: 'AGB' },
    ],
  },
];
---

<footer class="bg-primary-black border-t border-neutral-gray pt-10 pb-5 text-neutral-gray" role="contentinfo">
    <div class="max-w-[1200px] mx-auto px-5 max-sm:px-4">
        <div class="grid grid-cols-1 md:grid-cols-[2fr_1fr_1fr_1fr] gap-8 mb-8 max-md:text-center">
            <div>
                <div class="max-md:flex max-md:justify-center">
                    <Logo size="sm" />
                </div>
                <p class="text-neutral-gray text-[0.85rem] my-3 leading-normal">KI-gestützte Webentwicklung mit menschlicher Präzision. Für Unternehmen, die mehr wollen als eine hübsche Visitenkarte im Internet.</p>
                <p class="text-[0.7rem] tracking-[0.3em] text-accent-red uppercase mt-3">Precision AI Engineering</p>
            </div>
            {columns.map((col) => (
                <nav aria-label={col.title}>
                    <h4 class="font-mono text-[0.55rem] mb-4 text-steel-highlight tracking-[0.14em] font-medium uppercase">{col.title}</h4>
                    <ul class="list-none space-y-2">
                        {col.links.map(({ href, label }) => (
                            <li>
                                <a href={href} class="text-neutral-gray text-[0.8rem] transition-colors hover:text-accent-red focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-red">{label}</a>
                            </li>
                        ))}
                    </ul>
                </nav>
            ))}
        </div>
        <div class="border-t border-white/8 pt-5 text-center">
            <p class="text-steel-highlight text-[0.8rem] max-sm:text-[0.7rem] mb-1">&copy; {new Date().getFullYear()} Redline. Alle Rechte vorbehalten.</p>
            <p class="text-[0.7rem] max-sm:text-[0.65rem] text-steel-highlight italic max-w-[600px] mx-auto">Websites, die wirken — nicht nur existieren.</p>
        </div>
    </div>
</footer>
