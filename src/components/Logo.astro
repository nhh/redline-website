---
interface Props {
  size?: 'sm' | 'md';
}

const { size = 'md' } = Astro.props;
const textClass = size === 'sm' ? 'text-white' : 'text-primary-black';
const w = size === 'sm' ? 120 : 150;
const h = size === 'sm' ? 28 : 36;
---

<div class="flex items-center">
    <svg viewBox="0 0 150 36" width={w} height={h} aria-label="Redline Logo" role="img" class="block">
        <defs>
            <filter id={`glow-${size}`} x="-20%" y="-50%" width="140%" height="200%">
                <feGaussianBlur in="SourceGraphic" stdDeviation="1.5" result="blur"/>
                <feMerge>
                    <feMergeNode in="blur"/>
                    <feMergeNode in="SourceGraphic"/>
                </feMerge>
            </filter>
            <linearGradient id={`streak-grad-${size}`} x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#C41E3A" stop-opacity="0"/>
                <stop offset="15%" stop-color="#C41E3A" stop-opacity="0.8"/>
                <stop offset="50%" stop-color="#E8334F" stop-opacity="1"/>
                <stop offset="85%" stop-color="#C41E3A" stop-opacity="0.8"/>
                <stop offset="100%" stop-color="#C41E3A" stop-opacity="0"/>
            </linearGradient>
        </defs>

        <!-- Brand text -->
        <text
          x="8" y="22"
          font-family="Playfair Display, serif"
          font-size="24"
          font-weight="700"
          letter-spacing="-0.02em"
          class={textClass}
          fill="currentColor"
        >REDLINE</text>

        <!-- Red streak — behind/below the text, like a glowing underline -->
        <line
          x1="-5" y1="28"
          x2="155" y2="28"
          stroke={`url(#streak-grad-${size})`}
          stroke-width="2.5"
          stroke-linecap="round"
          filter={`url(#glow-${size})`}
        />

        <!-- Thinner hot core -->
        <line
          x1="5" y1="28"
          x2="145" y2="28"
          stroke="#E8334F"
          stroke-width="0.6"
          stroke-linecap="round"
          opacity="0.5"
        />
    </svg>
</div>
