---
interface Props {
  id: string;
  icon: string;
  title: string;
  description: string;
  tags: string[];
}

const { id, icon, title, description, tags } = Astro.props;
---

<article class="label-plate bg-bg-base border border-neutral-gray rounded-lg p-5 max-sm:p-4 transition-all duration-300 shadow-[0_2px_4px_rgba(0,0,0,0.05)] hover:border-accent-red hover:-translate-y-1.5 hover:shadow-[0_10px_30px_rgba(0,0,0,0.1)] relative" data-id={id}>
    <div class="text-xl mb-3 text-steel-light" aria-hidden="true">{icon}</div>
    <h3 class="font-sans text-[0.95rem] mb-2 font-semibold text-text-primary">{title}</h3>
    <p class="text-text-secondary text-[0.85rem] max-sm:text-[0.8rem] leading-relaxed mb-3">{description}</p>
    <ul class="flex flex-wrap gap-1 list-none" aria-label="Technologien">
        {tags.map((tag) => (
            <li><span class="inline-block font-mono text-[0.5rem] max-sm:text-[0.45rem] tracking-[0.08em] uppercase px-1.5 py-0.5 bg-red-muted text-accent-red border border-accent-red/15 rounded-[1px]">{tag}</span></li>
        ))}
    </ul>
</article>
