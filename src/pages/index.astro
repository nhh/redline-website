---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Section from '../components/Section.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import StepCard from '../components/StepCard.astro';
import ServiceCard from '../components/ServiceCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import FaqItem from '../components/FaqItem.astro';
import ScoreRing from '../components/ScoreRing.astro';
import MetricBar from '../components/MetricBar.astro';
import Footer from '../components/Footer.astro';

const problems = [
  { id: 'ISSUE-001', icon: '■', title: 'CMS-Ballast', body: '30 Plugins, 4 MB Ladelast, 3 Sekunden Wartezeit. <strong>Jede Sekunde Ladezeit kostet Conversion</strong>.' },
  { id: 'ISSUE-002', icon: '▲', title: 'Template-Einheitsbrei', body: 'Tausende Seiten sehen aus wie deine. Die Marke verschwindet im <strong>Theme-Rauschen</strong>.' },
  { id: 'ISSUE-003', icon: '◆', title: 'Stundensatz-Roulette', body: 'Agenturen verkaufen Zeit, nicht Ergebnis. Budgets laufen aus, <strong>die Seite ist trotzdem nicht live</strong>.' },
  { id: 'ISSUE-004', icon: '●', title: 'Wartungs-Abo auf Ewigkeit', body: 'WordPress patchen, Plugins aktualisieren, PHP-Versionen pflegen. <strong>Die Seite ist fertig — die Rechnung nie</strong>.' },
];

const services = [
  { id: 'SVC-001', icon: '◆', title: 'Landing Pages', description: 'Conversion-optimierte Einzelseiten für Produkte, Kampagnen oder Lead-Generierung. Schnell live, messbar wirksam.', tags: ['Astro', 'Conversion', 'Performance'] },
  { id: 'SVC-002', icon: '■', title: 'Unternehmenswebsites', description: 'Mehrseitige Auftritte, die Vertrauen aufbauen und Kompetenz kommunizieren. Klar strukturiert, inhaltlich durchdacht.', tags: ['CMS', 'Mehrsprachig', 'SEO'] },
  { id: 'SVC-003', icon: '▲', title: 'Web-Applikationen', description: 'Interaktive Tools, Dashboards, interne Anwendungen — wo eine Website nicht reicht und eine App zu viel wäre.', tags: ['React', 'API', 'Interaktiv'] },
  { id: 'SVC-004', icon: '●', title: 'Relaunch & Tuning', description: 'Deine Website läuft, performt aber nicht? Wir analysieren, identifizieren die Hebel und setzen um.', tags: ['Audit', 'Redesign', 'Speed'] },
];

const testimonials = [
  { quote: '"Zehn Tage vom Briefing bis zum Launch. Die alte Agentur hätte für dasselbe Monate gebraucht — und wäre noch in der Konzeptphase."', name: 'Katharina Wendt', role: 'Geschäftsführerin, Wendt Consulting' },
  { quote: '"100 Punkte bei PageSpeed — ohne dass wir danach fragen mussten. Die Conversion liegt 40 % über unserem alten Auftritt."', name: 'Markus Hahn', role: 'Head of Marketing, TechScale GmbH' },
  { quote: '"Direkte Kommunikation, kein Projektmanagement-Overhead, keine Handoffs zwischen Designer und Entwickler. So sollte Webentwicklung immer laufen."', name: 'Dr. Lena Fries', role: 'Gründerin, MedConnect' },
];

const faqs = [
  { q: 'Wie lange dauert ein Projekt?', a: 'Landing Pages: 3–5 Tage. Unternehmenswebsites: 7–10 Tage. Web-Apps individuell. Wir arbeiten in klaren Meilensteinen und halten Zeitpläne ein.' },
  { q: 'Was kostet eine Website?', a: 'Festpreis: <strong>1.000 € für das Grundgerüst (eine Seite)</strong>, plus <strong>150 € pro weiterer Unterseite</strong>. Texte und Formulierungen sind inklusive — du lieferst nur Bilder, Ideen und Inhalte. Ein 4-Seiter kostet also 1.450 €.' },
  { q: 'Was ist die kostenlose Arbeitsprobe?', a: 'Mit 1–3 Tagen Vorlauf bauen wir ein echtes Stück deiner neuen Seite — kostenlos, unverbindlich. Du siehst unseren Stil, unseren Code, unsere Geschwindigkeit, bevor du dich bindest.' },
  { q: 'Nutzt ihr WordPress?', a: 'Nein. Wir bauen <strong>statisch</strong> — mit Astro oder ähnlichen modernen Stacks. Das Ergebnis ist reines HTML/CSS/JS, das von einem CDN ausgeliefert wird. Schneller, sicherer, wartungsfrei. Brauchst du Redaktions-Features, binden wir ein schlankes Headless-CMS an.' },
  { q: 'Muss ich die Website warten lassen?', a: 'Nein. Statische Websites haben <strong>nichts, was gepatcht werden müsste</strong> — keine Datenbank, kein PHP, keine Plugin-Versionen. Die Seite läuft jahrelang ohne Wartung. Content-Änderungen buchst du bei Bedarf einzeln.' },
  { q: 'Bekomme ich den Quellcode?', a: 'Ja, vollständig. Der Code gehört dir — kein Vendor Lock-in, kein Abo, keine Blackbox. Du kannst jederzeit selbst weiterentwickeln oder einen anderen Entwickler beauftragen.' },
  { q: 'Was kosten spätere Änderungen?', a: 'Wenn du sie selbst machen willst: nichts — du hast den Code. Wenn wir dran sollen: Aufwandsschätzung im Voraus, Festpreis, keine Retainer. Content-Änderungen typischerweise ab 80 € pro Block.' },
  { q: 'Arbeitet ihr mit bestimmten Branchen?', a: 'Kein Branchenfokus. Wir bauen für Dienstleister, B2B, Startups, Handwerk und Industrie — überall, wo Websites verkaufen sollen.' },
  { q: 'Habt ihr eigene Produkte?', a: 'Ja — <a href="/stempel" class="underline text-accent-red">Stempel</a>, unsere selbstgebaute Arbeitszeiterfassung. Wir bauen nicht nur für Kunden, sondern setzen die gleichen Technologien für eigene Tools ein.' },
];

const features = [
  'Statisch gebaut — keine CMS-Updates, kein Wartungs-Abo',
  'PageSpeed 100 als Standard, nicht als Ausnahme',
  'Festpreis — keine Stundensätze, keine Überraschungen',
  'Ein Team für Design und Code — kein Ping-Pong, keine Handoffs',
  'Kompletter Source Code gehört dir',
  '5–10 Tage Projektlaufzeit, klare Meilensteine',
];

const metrics = [
  { value: '0.3s', name: 'First Contentful Paint', fill: 98 },
  { value: '0.4s', name: 'Largest Contentful Paint', fill: 96 },
  { value: '0ms', name: 'Total Blocking Time', fill: 100 },
  { value: '0', name: 'Cumulative Layout Shift', fill: 100 },
];

const agencyItems = ['Komplettes Redesign von Null', 'Neue Konzeptphase, neuer Workshop', 'Neue Informationsarchitektur', 'Neuer Content, neue Texte', '3–6 Monate Projektlaufzeit', '15.000 – 50.000 €'];
const upgradeItems = ['Modernisierung auf bestehendem Fundament', 'Die Konzeptarbeit steckt schon in deiner Seite', 'Struktur bleibt, Darstellung wird besser', 'Bestehende Texte schärfen statt wegwerfen', '5–10 Tage', 'Ein Bruchteil der Kosten'];

---

<Layout title="Redline — Websites, die wirken. Handwerklich gebaut.">

<div class="bg-texture fixed inset-0 -z-10 pointer-events-none bg-linear-to-br from-white to-bg-floor overflow-hidden" aria-hidden="true">
    <div class="bg-accent-glow bg-accent-glow-1"></div>
    <div class="bg-accent-glow bg-accent-glow-2"></div>
    <svg class="bg-snake" viewBox="0 0 1600 1000" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        <defs>
            <pattern id="snakeGrid" x="0" y="0" width="80" height="80" patternUnits="userSpaceOnUse">
                <circle cx="0" cy="0" r="0.8" fill="var(--color-accent-red)" opacity="0.18"/>
            </pattern>
        </defs>
        <rect width="1600" height="1000" fill="url(#snakeGrid)"/>
        <path class="snake snake-1" pathLength="100" d="M -40 160 L 240 160 L 240 320 L 480 320 L 480 240 L 720 240 L 720 400 L 1040 400 L 1040 560 L 1280 560"/>
        <path class="snake snake-2" pathLength="100" d="M 1640 720 L 1360 720 L 1360 560 L 1120 560 L 1120 800 L 880 800 L 880 640 L 560 640 L 560 880 L 240 880"/>
        <path class="snake snake-3" pathLength="100" d="M 1440 -40 L 1440 160 L 1280 160 L 1280 400 L 1520 400 L 1520 640 L 1360 640"/>
        <path class="snake snake-4" pathLength="100" d="M 160 -40 L 160 240 L 400 240 L 400 480 L 160 480 L 160 720 L 400 720"/>
    </svg>
</div>

<Navbar />

<!-- Brand Header -->
<section class="min-h-[200px] max-h-[300px] flex items-center justify-center bg-linear-to-br from-white to-bg-floor relative overflow-hidden px-8 py-8 mt-[52px] border-b border-neutral-gray md:h-[20vh]" aria-label="Marke">
    <div class="text-center z-10 relative w-full max-w-[1200px]">
        <h1 class="font-display text-[clamp(2.5rem,6vw,4.5rem)] font-bold tracking-tight text-primary-black mb-2 leading-none uppercase">Redline</h1>
        <p class="text-[clamp(0.75rem,1.5vw,1rem)] font-light tracking-[0.3em] text-text-muted uppercase mb-4">Precision Web Engineering</p>
        <div class="brand-divider w-20 h-0.5 bg-linear-to-r from-transparent via-accent-red to-transparent mx-auto relative"></div>
    </div>
</section>

<!-- Hero -->
<header id="main-content" class="px-5 py-16 max-w-[900px] mx-auto text-center">
    <div>
        <div class="badge-clip inline-flex items-center gap-2 bg-bg-base border border-border-dark px-2.5 py-1 font-mono text-[0.55rem] text-text-muted mb-5 font-medium tracking-[0.1em] uppercase shadow-[0_1px_2px_rgba(0,0,0,0.08)]">
            Statisch · Wartungsfrei · Festpreis
        </div>
        <h2 class="font-display text-[clamp(2rem,5vw,4rem)] font-bold leading-[1.15] mb-3.5 tracking-tight text-primary-black">Websites, die <span class="text-accent-red">wirken.</span></h2>
        <p class="text-lg text-text-secondary mb-3.5">Statisch gebaut. <span class="text-accent-red">Wartungsfrei</span>. Schnell.</p>
        <p class="text-[1rem] text-text-secondary mb-7 max-w-[620px] leading-relaxed mx-auto">
            Keine CMS-Updates, keine Plugin-Patches, kein Wartungs-Abo. Wir bauen statische Websites — als HTML vom CDN ausgeliefert. <strong>Gebaut, übergeben, fertig.</strong>
        </p>
        <div class="flex gap-3 mb-10 max-sm:flex-col justify-center">
            <Button href="#kontakt">
                <span>Projekt anfragen</span><span aria-hidden="true">→</span>
            </Button>
            <Button href="#prozess" variant="secondary">So arbeiten wir</Button>
        </div>
        <div class="flex max-sm:flex-col bg-bg-base border border-border-mid rounded-[1px] overflow-hidden shadow-[0_2px_4px_rgba(0,0,0,0.06)]" role="list" aria-label="Kennzahlen">
            {[
              { label: 'METRIC-A', value: '100', text: 'PageSpeed-Score' },
              { label: 'METRIC-B', value: '5–10T', text: 'Bis Go-Live' },
              { label: 'METRIC-C', value: '0', text: 'Stundensatz-Roulette' },
            ].map((stat, i, arr) => (
                <div class:list={['py-4 px-5 text-left relative flex-1', i < arr.length - 1 && 'border-r max-sm:border-r-0 max-sm:border-b border-border-dark']} role="listitem">
                    <span class="absolute top-1.5 left-2 font-mono text-[0.45rem] text-text-muted tracking-[0.1em] uppercase">{stat.label}</span>
                    <span class="block font-mono text-xl font-semibold text-text-primary mt-2">{stat.value}</span>
                    <span class="text-[0.55rem] text-text-muted uppercase tracking-[0.1em] font-medium">{stat.text}</span>
                </div>
            ))}
        </div>
    </div>
</header>

<main>
<!-- Problem -->
<Section id="problem" gray>
    <SectionHeader subtitle="Warum die meisten Websites nicht verkaufen — und wir es anders machen.">Das <span class="text-accent-red">Problem</span> mit Webprojekten</SectionHeader>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6 reveal-stagger">
        {problems.map((p) => (
            <Card id={p.id}>
                <div class="text-lg pt-3.5 px-4 pb-1.5 text-steel-light" aria-hidden="true">{p.icon}</div>
                <h3 class="font-sans text-[0.65rem] px-4 mb-1.5 text-text-label font-semibold uppercase tracking-[0.1em]">{p.title}</h3>
                <p class="text-text-secondary text-[0.85rem] max-sm:text-[0.8rem] leading-relaxed px-4 pb-4" set:html={p.body} />
            </Card>
        ))}
    </div>
</Section>

<!-- Modernisierung -->
<Section id="modernisierung">
    <SectionHeader subtitle="Die meisten Websites brauchen keinen Neuanfang. Sie brauchen ein Upgrade.">Deine Website ist besser als du <span class="text-accent-red">denkst</span></SectionHeader>
    <div class="flex flex-col gap-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 reveal-stagger">
            <Card id="APPROACH-A" hover={false}>
                <div class="font-mono text-[0.6rem] font-semibold uppercase tracking-[0.12em] px-4 py-3 text-center border-b bg-red-muted text-accent-red border-b-accent-red/15">Was Agenturen verkaufen</div>
                <ul class="px-4 py-2 list-none">
                    {agencyItems.map((item, i) => (
                        <li class:list={['text-[0.85rem] max-sm:text-[0.8rem] text-text-muted py-2 leading-snug', i < agencyItems.length - 1 && 'border-b border-border-dark']}>{item}</li>
                    ))}
                </ul>
            </Card>
            <Card id="APPROACH-B" hover={false} class="border-pass-border!">
                <div class="font-mono text-[0.6rem] font-semibold uppercase tracking-[0.12em] px-4 py-3 text-center border-b bg-pass-muted text-pass border-b-pass/15">Was meistens reicht</div>
                <ul class="px-4 py-2 list-none">
                    {upgradeItems.map((item, i) => (
                        <li class:list={['text-[0.85rem] max-sm:text-[0.8rem] text-text-secondary py-2 leading-snug', i < upgradeItems.length - 1 && 'border-b border-border-dark']}>{item}</li>
                    ))}
                </ul>
            </Card>
        </div>
        <div class="max-w-[680px] mx-auto">
            <p class="text-text-secondary text-[0.95rem] max-sm:text-[0.85rem] leading-relaxed text-center max-md:text-left">Deine Website hat schon <strong>Konzept, Struktur und Inhalt</strong> — das ist das Fundament. Statt alles wegzuwerfen, modernisieren wir gezielt, was bleibt, und ersetzen, was nicht mehr trägt.</p>
        </div>
    </div>
</Section>

<!-- Was uns ausmacht -->
<Section id="warum" gray>
    <SectionHeader subtitle="Der Deal in sechs Punkten.">Was du <span class="text-accent-red">bekommst</span></SectionHeader>
    <div class="max-w-[760px] mx-auto reveal">
        <ul class="list-none bg-bg-base border border-border-mid rounded-[1px] p-1.5 shadow-[0_1px_2px_rgba(0,0,0,0.08)]" role="list">
            {features.map((f, i) => (
                <li class:list={['py-2 px-3 flex items-center gap-2.5 text-text-secondary text-[0.9rem]', i < features.length - 1 && 'border-b border-border-dark']}>
                    <span class="text-pass font-bold text-[0.8rem]" aria-hidden="true">✓</span> {f}
                </li>
            ))}
        </ul>
    </div>
</Section>

<!-- Prozess -->
<Section id="prozess">
    <SectionHeader subtitle="Drei Schritte. Keine Konzeptphase, keine Handoffs, keine Moodboard-Schleifen.">So <span class="text-accent-red">arbeiten</span> wir</SectionHeader>
    <div class="flex flex-col gap-3.5 reveal-stagger">
        <StepCard num="01" batch="PHASE-01" title="Bestand analysieren">
            <p class="text-text-secondary leading-relaxed text-[0.9rem] max-sm:text-[0.8rem]">Wir sehen uns <strong>deine bestehende Website</strong> an, identifizieren Lücken, Performance-Probleme und ungenutzte Chancen. Am Ende steht ein klarer Befund — keine 40-Seiten-Strategie.</p>
        </StepCard>
        <StepCard num="02" batch="PHASE-02" title="Neu bauen mit deinen Wünschen">
            <p class="text-text-secondary leading-relaxed text-[0.9rem] max-sm:text-[0.8rem]">Wir bauen die <strong>verbesserte Website</strong> — inklusive deiner Individualisierungswünsche. Du lieferst Bilder, Ideen und Inhalte. Den Rest machen wir.</p>
        </StepCard>
        <StepCard num="03" batch="PHASE-03" title="Launch & Tuning">
            <p class="text-text-secondary leading-relaxed text-[0.9rem] max-sm:text-[0.8rem]">Performance, SEO, Analytics. <strong>Wir gehen nicht live, bis PageSpeed 100 zeigt.</strong> Danach: übergeben, Source-Code inklusive.</p>
        </StepCard>
    </div>

    <div class="max-w-[760px] mx-auto mt-8 reveal">
        <div class="bg-bg-base border border-accent-red rounded-[2px] px-5 py-4 max-sm:px-4 max-sm:py-3.5 flex items-start gap-4 shadow-[0_4px_16px_rgba(196,30,58,0.10)]">
            <div class="font-mono text-[0.55rem] text-accent-red tracking-[0.14em] uppercase font-semibold shrink-0 mt-0.5 whitespace-nowrap">Arbeitsprobe · gratis</div>
            <div class="flex-1">
                <p class="text-[0.9rem] max-sm:text-[0.85rem] text-text-secondary leading-snug">Unsicher, ob es passt? Mit <strong class="text-text-primary">1–3 Tagen Vorlauf</strong> bauen wir eine kostenlose Arbeitsprobe — ein echtes Stück deiner neuen Seite, bevor du dich entscheidest.</p>
            </div>
            <a href="#kontakt" class="font-mono text-[0.6rem] tracking-[0.12em] uppercase font-semibold text-accent-red whitespace-nowrap shrink-0 mt-1 hover:underline max-sm:hidden">Anfragen →</a>
        </div>
    </div>
</Section>

<!-- Services -->
<Section id="leistungen" gray>
    <SectionHeader subtitle="Kein Full-Service-Bauchladen. Fokus auf das, was wir exzellent können.">Was wir <span class="text-accent-red">bauen</span></SectionHeader>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6 reveal-stagger mb-12">
        {services.map((svc) => <ServiceCard {...svc} />)}
    </div>

    <!-- Preise -->
    <div id="preise" class="max-w-[960px] mx-auto reveal">
        <div class="text-center mb-6">
            <div class="font-mono text-[0.55rem] text-text-muted tracking-[0.14em] uppercase mb-2">Preise · Festpreis</div>
            <h3 class="font-display text-2xl max-sm:text-xl font-bold mb-2 leading-tight">Transparent. <span class="text-accent-red">Einfach.</span></h3>
            <p class="text-text-secondary text-[0.95rem] max-sm:text-[0.9rem] max-w-[600px] mx-auto leading-relaxed">Du zahlst ein Grundgerüst und bezahlst pro weiterer Unterseite. Formulierungen inklusive — du lieferst nur Bilder, Ideen und Inhalt.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="bg-bg-base border border-border-mid rounded-[2px] p-6 max-sm:p-5 shadow-[0_2px_4px_rgba(0,0,0,0.05)]">
                <div class="font-mono text-[0.55rem] text-text-muted tracking-[0.14em] uppercase mb-2">Basis</div>
                <div class="flex items-baseline gap-2 mb-1">
                    <span class="font-display text-4xl font-bold text-text-primary">1.000 €</span>
                    <span class="font-mono text-[0.65rem] text-text-muted">Festpreis</span>
                </div>
                <div class="text-[0.75rem] text-text-muted mb-4">Grundgerüst · eine Seite</div>
                <ul class="list-none flex flex-col gap-1.5 text-[0.85rem] text-text-secondary">
                    <li class="flex items-start gap-2"><span class="text-pass font-bold mt-0.5" aria-hidden="true">✓</span> Design, Entwicklung, Launch</li>
                    <li class="flex items-start gap-2"><span class="text-pass font-bold mt-0.5" aria-hidden="true">✓</span> Texte & Formulierungen inklusive</li>
                    <li class="flex items-start gap-2"><span class="text-pass font-bold mt-0.5" aria-hidden="true">✓</span> PageSpeed 100 &amp; responsives Layout</li>
                    <li class="flex items-start gap-2"><span class="text-pass font-bold mt-0.5" aria-hidden="true">✓</span> Source-Code gehört dir</li>
                </ul>
            </div>
            <div class="bg-bg-base border border-accent-red rounded-[2px] p-6 max-sm:p-5 shadow-[0_4px_16px_rgba(196,30,58,0.12)] relative">
                <span class="absolute -top-2.5 left-5 bg-accent-red text-white font-mono text-[0.55rem] tracking-[0.14em] uppercase font-semibold px-2 py-1 rounded-[1px]">Pro Unterseite</span>
                <div class="font-mono text-[0.55rem] text-text-muted tracking-[0.14em] uppercase mb-2">Erweiterung</div>
                <div class="flex items-baseline gap-2 mb-1">
                    <span class="font-display text-4xl font-bold text-text-primary">150 €</span>
                    <span class="font-mono text-[0.65rem] text-text-muted">pro Unterseite</span>
                </div>
                <div class="text-[0.75rem] text-text-muted mb-4">Additiv zum Grundgerüst</div>
                <ul class="list-none flex flex-col gap-1.5 text-[0.85rem] text-text-secondary">
                    <li class="flex items-start gap-2"><span class="text-pass font-bold mt-0.5" aria-hidden="true">✓</span> Neues Layout oder Variante</li>
                    <li class="flex items-start gap-2"><span class="text-pass font-bold mt-0.5" aria-hidden="true">✓</span> Texte passend zur Seite</li>
                    <li class="flex items-start gap-2"><span class="text-pass font-bold mt-0.5" aria-hidden="true">✓</span> In Navigation integriert</li>
                    <li class="flex items-start gap-2"><span class="text-pass font-bold mt-0.5" aria-hidden="true">✓</span> Gleiche Performance-Garantie</li>
                </ul>
            </div>
        </div>
        <div class="mt-6 bg-bg-base border border-border-dark rounded-[1px] px-4 py-3 flex items-start gap-3 max-w-[720px] mx-auto">
            <span class="font-mono text-[0.6rem] text-accent-red tracking-[0.12em] uppercase font-semibold shrink-0 mt-0.5">Du lieferst</span>
            <span class="text-[0.85rem] text-text-secondary leading-snug">Bilder, Ideen, Inhalte. <strong class="text-text-primary">Alles andere machen wir.</strong> Beispiel: 4-Seiter komplett = 1.000 € + 3 × 150 € = <strong class="text-text-primary">1.450 €</strong>.</span>
        </div>
    </div>
</Section>

<!-- PageSpeed -->
<Section id="performance">
    <SectionHeader subtitle="Unsere Websites bestehen den Google PageSpeed Test mit Bestnote — nicht als Ausnahme, sondern als Standard."><span class="text-accent-red">100</span> Punkte. Jedes Mal.</SectionHeader>
    <div class="label-plate-lighthouse reveal grid grid-cols-1 lg:grid-cols-[auto_1fr] gap-8 lg:gap-12 items-center bg-bg-base border border-border-mid rounded-lg p-6 max-sm:p-5 shadow-[0_2px_4px_rgba(0,0,0,0.06)] relative mb-6">
        <div class="flex max-sm:grid max-sm:grid-cols-2 gap-5 max-sm:gap-4 lg:gap-6 justify-center">
            {['Performance', 'Accessibility', 'Best Practices', 'SEO'].map((label) => <ScoreRing label={label} />)}
        </div>
        <div class="flex flex-col gap-3">
            {metrics.map((m) => <MetricBar {...m} />)}
        </div>
    </div>
    <p class="text-center text-[0.8rem] text-text-muted">Ergebnis dieser Website — jetzt prüfbar auf <strong>PageSpeed Insights</strong>. Kein Testserver, keine Trickserei.</p>
</Section>

<!-- Testimonials -->
<Section id="referenzen" gray>
    <SectionHeader subtitle="Ergebnisse statt Versprechen.">Was Kunden <span class="text-accent-red">sagen</span></SectionHeader>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 reveal-stagger">
        {testimonials.map((t) => <TestimonialCard {...t} />)}
    </div>
</Section>

