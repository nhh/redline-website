---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Section from '../components/Section.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import StepCard from '../components/StepCard.astro';
import ServiceCard from '../components/ServiceCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import FaqItem from '../components/FaqItem.astro';
import ScoreRing from '../components/ScoreRing.astro';
import MetricBar from '../components/MetricBar.astro';
import Footer from '../components/Footer.astro';

const problems = [
  { id: 'ISSUE-001', icon: '■', title: 'Agenturen verkaufen Theorie', body: 'Klassische Webagenturen präsentieren Konzepte, Moodboards und Wireframes. Du bezahlst <strong>bevor du etwas Echtes siehst</strong>. Wochen vergehen, tausende Euro fließen — und am Ende passt es vielleicht nicht.' },
  { id: 'ISSUE-002', icon: '▲', title: 'KI allein liefert Mittelmaß', body: 'KI kann Code schreiben und Layouts erzeugen. Aber sie versteht nicht, warum ein Besucher bei dir kaufen soll. Sie kennt deine Marke nicht, deine Zielgruppe nicht, dein Geschäftsmodell nicht. <strong>Ohne jemanden, der sie steuert, produziert sie nur hübschen Durchschnitt.</strong>' },
  { id: 'ISSUE-003', icon: '◆', title: 'Kaufen im Blindflug', body: 'Ob 3.000 € oder 30.000 € — du weißt erst nach Monaten, ob sich die Investition gelohnt hat. <strong>Kein anderer Dienstleister</strong> erwartet, dass du ein Produkt kaufst, das du vorher nicht sehen kannst.' },
  { id: 'ISSUE-004', icon: '●', title: 'Fehlende Iteration', body: 'KI generiert einen Entwurf — aber sie weiß nicht, ob er funktioniert. Sie testet nicht, sie hinterfragt nicht, sie optimiert nicht. <strong>Ohne menschliche Iteration</strong> bleibt das Ergebnis am Ausgangspunkt stehen.' },
];

const services = [
  { id: 'SVC-001', icon: '◆', title: 'Landing Pages', description: 'Conversion-optimierte Einzelseiten für Produkte, Kampagnen oder Lead-Generierung. Schnell live, messbar wirksam.', tags: ['Astro', 'Conversion', 'Performance'] },
  { id: 'SVC-002', icon: '■', title: 'Unternehmenswebsites', description: 'Mehrseitige Auftritte, die Vertrauen aufbauen und Kompetenz kommunizieren. Klar strukturiert, inhaltlich durchdacht.', tags: ['CMS', 'Mehrsprachig', 'SEO'] },
  { id: 'SVC-003', icon: '▲', title: 'Web-Applikationen', description: 'Interaktive Tools, Dashboards und interne Anwendungen. Wo eine Website nicht reicht und eine App zu viel wäre.', tags: ['React', 'API', 'Interaktiv'] },
  { id: 'SVC-004', icon: '●', title: 'Relaunch & Optimierung', description: 'Deine bestehende Website funktioniert, aber performt nicht? Wir analysieren, identifizieren Hebel und setzen um.', tags: ['Audit', 'Redesign', 'Speed'] },
];

const testimonials = [
  { quote: '"Ich hatte schon zwei Agenturen beauftragt, die nach wochenlanger Konzeptphase Ergebnisse lieferten, die mich nicht überzeugten. Redline hat einfach gebaut — und es hat sofort gepasst."', name: 'Katharina Wendt', role: 'Geschäftsführerin, Wendt Consulting' },
  { quote: '"Der kostenlose Umbau hat mich ehrlich gesagt skeptisch gemacht. Dann habe ich das Ergebnis gesehen — und sofort den Feinschliff beauftragt. Conversion liegt 40% über dem alten Auftritt."', name: 'Markus Hahn', role: 'Head of Marketing, TechScale GmbH' },
  { quote: '"Zum ersten Mal konnte ich meinem Team eine neue Website zeigen, bevor wir auch nur einen Euro ausgegeben haben. Das hat intern sofort Vertrauen geschaffen."', name: 'Dr. Lena Fries', role: 'Gründerin, MedConnect' },
];

const faqs = [
  { q: 'Was kostet die Arbeitsprobe?', a: 'Nichts. Der erste Umbau ist unsere Art zu zeigen, was wir können. Kein Haken, kein Abo. Wenn dir das Ergebnis gefällt, machen wir ein Angebot für den Feinschliff. Wenn nicht, war es das.' },
  { q: 'Was genau ist der "Feinschliff"?', a: 'Die Arbeitsprobe liefert eine solide neue Version deiner Website. Der Feinschliff macht sie perfekt: individuelle Textarbeit, Conversion-Optimierung, spezielle Funktionen, SEO-Tuning. Nur das, was du wirklich brauchst.' },
  { q: 'Warum baut ihr zuerst?', a: 'Weil Ergebnisse mehr sagen als Pitch-Decks. Wer seine neue Website sieht, muss keine Fantasie aufbringen. KI gibt uns die Geschwindigkeit, diesen Umbau in Stunden statt Wochen umzusetzen. Aber ohne unsere Expertise würde dabei nur generischer Output entstehen — deshalb funktioniert es nur mit beidem.' },
  { q: 'Was kostet der Feinschliff?', a: 'Abhängig vom Umfang, typischerweise zwischen 1.500 und 5.000 €. Du bekommst ein konkretes Angebot basierend auf dem, was du an der umgebauten Website noch anpassen möchtest. Festpreis, kein Stundensatz-Roulette.' },
  { q: 'Sehen KI-Websites nicht alle gleich aus?', a: 'Ja — wenn niemand die KI steuert. Das ist genau der Punkt. KI allein produziert austauschbare Ergebnisse. Der Unterschied ist, wer ihr sagt, was sie bauen soll, was sie ändern muss und wann es gut genug ist. Das können nur Menschen mit Erfahrung. Jedes unserer Projekte ist individuell.' },
  { q: 'Bekomme ich den Source Code?', a: 'Ja, vollständig. Der komplette Quellcode gehört dir — kein Vendor Lock-in, kein proprietäres System, kein Abo. Du kannst jederzeit selbst weiterentwickeln oder einen anderen Entwickler beauftragen.' },
  { q: 'Brauche ich eine bestehende Website?', a: 'Für die Arbeitsprobe ja — wir brauchen eine Basis zum Umbauen. Dazu deine Wünsche und 2-3 Referenz-Websites als Orientierung. Du hast noch keine Seite? Meld dich trotzdem — wir finden eine Lösung.' },
];

const features = [
  'Umbau deiner Website als Arbeitsprobe',
  'Ergebnis sehen, bevor du dich entscheidest',
  'KI als Werkzeug — gesteuert von erfahrenen Entwicklern',
  'Jede Entscheidung wird von Menschen getroffen und geprüft',
  'Kein Template — individuell für dich gebaut',
  'Kompletter Source Code gehört dir',
];

const metrics = [
  { value: '0.3s', name: 'First Contentful Paint', fill: 98 },
  { value: '0.4s', name: 'Largest Contentful Paint', fill: 96 },
  { value: '0ms', name: 'Total Blocking Time', fill: 100 },
  { value: '0', name: 'Cumulative Layout Shift', fill: 100 },
];

const gapLeft = ['Strategie-Workshops', 'Moodboards & Wireframes', 'User Journeys', 'Content-Konzepte', 'Abstimmungsrunden'];
const gapRight = ['Design-Umsetzung', 'Frontend-Entwicklung', 'CMS-Integration', 'Testing & QA', 'Korrekturschleifen'];
const agencyItems = ['Komplettes Redesign von Null', 'Neue Konzeptphase, neuer Workshop', 'Neue Informationsarchitektur', 'Neuer Content, neue Texte', '3-6 Monate Projektlaufzeit', '15.000 - 50.000 €'];
const upgradeItems = ['Modernisierung auf bestehendem Fundament', 'Die Konzeptarbeit steckt schon in deiner Seite', 'Struktur bleibt, Darstellung wird besser', 'Bestehende Texte schärfen statt wegwerfen', 'Tage bis wenige Wochen', 'Ein Bruchteil der Kosten'];
---

<Layout title="Redline — KI-gesteuerte Webentwicklung mit menschlicher Präzision">

<div class="bg-texture fixed inset-0 -z-10 pointer-events-none bg-linear-to-br from-white to-bg-floor"></div>

<Navbar />

<!-- Brand Header -->
<section class="min-h-[200px] max-h-[300px] flex items-center justify-center bg-linear-to-br from-white to-bg-floor relative overflow-hidden px-8 py-8 mt-[52px] border-b border-neutral-gray md:h-[20vh]" aria-label="Marke">
    <div class="text-center z-10 relative w-full max-w-[1200px]">
        <h1 class="font-display text-[clamp(2.5rem,6vw,4.5rem)] font-bold tracking-tight text-primary-black mb-2 leading-none uppercase">Redline</h1>
        <p class="text-[clamp(0.75rem,1.5vw,1rem)] font-light tracking-[0.3em] text-text-muted uppercase mb-4">Precision Web Engineering</p>
        <div class="brand-divider w-20 h-0.5 bg-linear-to-r from-transparent via-accent-red to-transparent mx-auto relative"></div>
    </div>
</section>

<!-- Hero -->
<header id="main-content" class="px-5 py-16 max-w-[900px] mx-auto text-center">
    <div>
        <div class="badge-clip inline-flex items-center gap-2 bg-bg-base border border-border-dark px-2.5 py-1 font-mono text-[0.55rem] text-text-muted mb-5 font-medium tracking-[0.1em] uppercase shadow-[0_1px_2px_rgba(0,0,0,0.08)]">
            SYS-001 · KI-gestützt · Ergebnis vor Angebot · Menschlich gesteuert
        </div>
        <h2 class="font-display text-[clamp(2rem,5vw,4rem)] font-bold leading-[1.15] mb-3.5 tracking-tight text-primary-black">Wir reden nicht. Wir <span class="text-accent-red">bauen.</span></h2>
        <p class="text-lg text-text-secondary mb-3.5">Deine Website, neu gedacht — als <span class="text-accent-red">Arbeitsprobe</span>.</p>
        <p class="text-[1rem] text-text-secondary mb-7 max-w-[640px] leading-relaxed mx-auto">
            KI kann Websites generieren. Aber <strong>ohne uns steuert sie im Blindflug</strong>.
            Wir verbinden jahrelange Web-Expertise mit KI-Geschwindigkeit — und bauen deine bestehende Seite um, bevor du dich entscheidest. Kein Konzept. Ein <strong>Ergebnis</strong>.
        </p>
        <div class="flex gap-3 mb-10 max-sm:flex-col justify-center">
            <Button href="#kontakt">
                <span>Arbeitsprobe anfragen</span><span aria-hidden="true">→</span>
            </Button>
            <Button href="#prozess" variant="secondary">So funktioniert's</Button>
        </div>
        <div class="flex max-sm:flex-col bg-bg-base border border-border-mid rounded-[1px] overflow-hidden shadow-[0_2px_4px_rgba(0,0,0,0.06)]" role="list" aria-label="Kennzahlen">
            {[
              { label: 'METRIC-A', value: '3x', text: 'Schneller als klassisch' },
              { label: 'METRIC-B', value: '100%', text: 'Ergebnis vorab' },
              { label: 'METRIC-C', value: '0', text: 'Konzept-PDFs' },
            ].map((stat, i, arr) => (
                <div class:list={['py-4 px-5 text-left relative flex-1', i < arr.length - 1 && 'border-r max-sm:border-r-0 max-sm:border-b border-border-dark']} role="listitem">
                    <span class="absolute top-1.5 left-2 font-mono text-[0.45rem] text-text-muted tracking-[0.1em] uppercase">{stat.label}</span>
                    <span class="block font-mono text-xl font-semibold text-text-primary mt-2">{stat.value}</span>
                    <span class="text-[0.55rem] text-text-muted uppercase tracking-[0.1em] font-medium">{stat.text}</span>
                </div>
            ))}
        </div>
    </div>
</header>

<main>
<!-- Problem -->
<Section id="problem" gray>
    <SectionHeader subtitle="KI ist mächtig. Aber ohne Erfahrung, die sie lenkt, ist sie nur ein schneller Zufallsgenerator.">Das <span class="text-accent-red">Problem</span> mit Webprojekten</SectionHeader>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6 reveal-stagger">
        {problems.map((p) => (
            <Card id={p.id}>
                <div class="text-lg pt-3.5 px-4 pb-1.5 text-steel-light" aria-hidden="true">{p.icon}</div>
                <h3 class="font-sans text-[0.65rem] px-4 mb-1.5 text-text-label font-semibold uppercase tracking-[0.1em]">{p.title}</h3>
                <p class="text-text-secondary text-[0.85rem] max-sm:text-[0.8rem] leading-relaxed px-4 pb-4" set:html={p.body} />
            </Card>
        ))}
    </div>
</Section>

<!-- Gap -->
<Section id="gap">
    <SectionHeader subtitle="Warum die meisten Webprojekte scheitern oder 3x so lange dauern — und wie wir mit KI das ändern.">Der <span class="text-accent-red">Gap</span> zwischen Idee und Website</SectionHeader>
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_auto_1fr] mb-10 reveal">
        <div class="flex">
            <Card id="GAP-LEFT" hover={false} class="flex-1 flex flex-col">
                <div class="font-mono text-[0.6rem] font-semibold uppercase tracking-[0.12em] px-4 py-3 border-b border-border-dark text-text-muted bg-bg-base">Konzeption</div>
                <ul class="px-4 py-3 flex-1 list-none">
                    {gapLeft.map((item, i) => (
                        <li class:list={['text-[0.8rem] max-sm:text-[0.75rem] text-text-secondary py-1.5', i < gapLeft.length - 1 && 'border-b border-border-dark']}>◆ {item}</li>
                    ))}
                </ul>
                <div class="font-mono text-[0.55rem] text-text-muted tracking-[0.08em] uppercase px-4 py-2.5 border-t border-border-dark bg-bg-inset text-center">Wochen 1-6</div>
            </Card>
        </div>
        <div class="flex flex-col items-center justify-center px-6 py-6 lg:py-0 min-w-[180px] max-lg:min-w-0">
            <div class="text-center py-4">
                <div class="font-mono text-[0.65rem] font-bold tracking-[0.1em] uppercase text-accent-red mb-2">Der Gap</div>
                <p class="text-[0.75rem] text-text-muted leading-snug max-w-[160px] max-lg:max-w-full">Wochen bis Monate, in denen aus Theorie Realität werden muss. Hier scheitern Budgets, Timelines und Erwartungen.</p>
            </div>
            <div class="my-2" aria-hidden="true">
                <svg viewBox="0 0 40 80" width="40" height="80"><path d="M20,5 L20,55" stroke="var(--color-accent-red)" stroke-width="2" fill="none" stroke-dasharray="4,4" class="arrow-gap-anim"/><polygon points="20,65 14,52 26,52" fill="var(--color-accent-red)"/></svg>
            </div>
            <div class="flex items-center gap-2 bg-pass-muted border border-pass-border rounded-[1px] px-3 py-2">
                <span class="text-pass text-[0.9rem]" aria-hidden="true">◉</span>
                <span class="font-mono text-[0.55rem] font-semibold tracking-[0.08em] uppercase text-pass">Wir + KI schließen den Gap</span>
            </div>
        </div>
        <div class="flex">
            <Card id="GAP-RIGHT" hover={false} class="flex-1 flex flex-col">
                <div class="font-mono text-[0.6rem] font-semibold uppercase tracking-[0.12em] px-4 py-3 border-b border-border-dark text-text-muted bg-bg-base">Umsetzung</div>
                <ul class="px-4 py-3 flex-1 list-none">
                    {gapRight.map((item, i) => (
                        <li class:list={['text-[0.8rem] max-sm:text-[0.75rem] text-text-secondary py-1.5', i < gapRight.length - 1 && 'border-b border-border-dark']}>◆ {item}</li>
                    ))}
                </ul>
                <div class="font-mono text-[0.55rem] text-text-muted tracking-[0.08em] uppercase px-4 py-2.5 border-t border-border-dark bg-bg-inset text-center">Wochen 7-14</div>
            </Card>
        </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 reveal-stagger">
        <div class="bg-bg-base border border-neutral-gray rounded-lg p-5 shadow-[0_2px_4px_rgba(0,0,0,0.05)]">
            <h3 class="font-sans text-[0.75rem] font-semibold uppercase tracking-[0.08em] mb-2 text-text-primary">Das klassische Problem</h3>
            <p class="text-[0.85rem] text-text-secondary leading-relaxed">Zwischen Konzeption und fertiger Website liegen <strong>Wochen der Übersetzungsarbeit</strong>. Designer interpretieren das Konzept. Entwickler interpretieren das Design. Bei jeder Übergabe geht Intention verloren. Am Ende sieht die Website anders aus als gedacht — und das Budget ist aufgebraucht.</p>
        </div>
        <div class="bg-pass-muted border border-pass-border rounded-lg p-5">
            <h3 class="font-sans text-[0.75rem] font-semibold uppercase tracking-[0.08em] mb-2 text-text-primary">Wie wir mit KI den Gap schließen</h3>
            <p class="text-[0.85rem] text-text-secondary leading-relaxed">Wir nutzen KI als Werkzeug, um aus einer Idee <strong>in Stunden einen funktionierenden Prototyp</strong> zu bauen. Aber die KI entscheidet nicht — wir entscheiden. Welches Layout funktioniert, welcher Text überzeugt, welche Struktur konvertiert. Das ist Erfahrung, kein Algorithmus. Fehler fallen sofort auf, Korrekturen kosten Minuten statt Sprints.</p>
        </div>
    </div>
</Section>

<!-- Modernisierung -->
<Section id="modernisierung" gray>
    <SectionHeader subtitle="Die meisten Websites brauchen keinen Neuanfang. Sie brauchen ein Upgrade.">Deine Website ist besser als du <span class="text-accent-red">denkst</span></SectionHeader>
    <div class="flex flex-col gap-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 reveal-stagger">
            <Card id="APPROACH-A" hover={false}>
                <div class="font-mono text-[0.6rem] font-semibold uppercase tracking-[0.12em] px-4 py-3 text-center border-b bg-red-muted text-accent-red border-b-accent-red/15">Was Agenturen verkaufen</div>
                <ul class="px-4 py-2 list-none">
                    {agencyItems.map((item, i) => (
                        <li class:list={['text-[0.85rem] max-sm:text-[0.8rem] text-text-muted py-2 leading-snug', i < agencyItems.length - 1 && 'border-b border-border-dark']}>{item}</li>
                    ))}
                </ul>
            </Card>
            <Card id="APPROACH-B" hover={false} class="border-pass-border!">
                <div class="font-mono text-[0.6rem] font-semibold uppercase tracking-[0.12em] px-4 py-3 text-center border-b bg-pass-muted text-pass border-b-pass/15">Was meistens reicht</div>
                <ul class="px-4 py-2 list-none">
                    {upgradeItems.map((item, i) => (
                        <li class:list={['text-[0.85rem] max-sm:text-[0.8rem] text-text-secondary py-2 leading-snug', i < upgradeItems.length - 1 && 'border-b border-border-dark']}>{item}</li>
                    ))}
                </ul>
            </Card>
        </div>
        <div class="max-w-[720px] mx-auto">
            <p class="text-text-secondary text-[0.95rem] max-sm:text-[0.85rem] leading-relaxed mb-3.5 text-center max-md:text-left">Deine Website hat bereits <strong>Konzeptionsphasen durchlaufen</strong>. Jemand hat sich Gedanken über Struktur, Inhalte und Zielgruppe gemacht. Diese Arbeit ist nicht wertlos — sie ist das Fundament.</p>
            <p class="text-text-secondary text-[0.95rem] max-sm:text-[0.85rem] leading-relaxed mb-3.5 text-center max-md:text-left">Trotzdem will dir jede Agentur einen <strong>kompletten Relaunch verkaufen</strong>. Neues Konzept, neues Design, neuer Content. Von vorn. Nicht weil es nötig wäre, sondern weil sich damit mehr Geld verdienen lässt.</p>
            <p class="text-text-secondary text-[0.95rem] max-sm:text-[0.85rem] leading-relaxed text-center max-md:text-left">Die Wahrheit: In den meisten Fällen reicht eine <strong>gezielte Modernisierung</strong>. KI gibt uns die Geschwindigkeit dafür — aber nur unsere Erfahrung entscheidet, was bleibt, was sich ändert und warum. Aufbauen auf dem, was da ist — statt alles wegzuwerfen und bei Null zu starten.</p>
        </div>
    </div>
</Section>

<!-- Ansatz -->
<Section id="ansatz">
    <SectionHeader subtitle="Wir zeigen, was wir können — bevor du dich entscheidest.">Ergebnis vor <span class="text-accent-red">Angebot</span></SectionHeader>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start reveal">
        <div>
            <h3 class="font-sans text-[1.05rem] mb-3.5 font-semibold">Deine Website als Arbeitsprobe</h3>
            <p class="text-text-secondary mb-3.5 leading-relaxed text-[0.95rem]">Wir nehmen deine bestehende Website und bauen sie um — als <strong>Demonstration unserer Arbeit</strong>. Die KI liefert die Geschwindigkeit, aber <strong>wir liefern die Richtung</strong>: Welche Struktur überzeugt, welcher Ton zu deiner Marke passt, was einen Besucher zum Kunden macht.</p>
            <p class="text-text-secondary mb-3.5 leading-relaxed text-[0.95rem]">Ohne unsere Steuerung wäre das Ergebnis generisch. Mit unserer Erfahrung wird es <strong>ein Produkt, das es schon gibt</strong> — bevor du dich entscheidest.</p>
            <p class="text-text-secondary mb-3.5 leading-relaxed text-[0.95rem]">Klassische Agenturen verkaufen Versprechen. KI-Tools liefern Durchschnitt. Wir verkaufen <strong>geprüfte Ergebnisse</strong>.</p>
            <ul class="list-none mb-4 bg-bg-base border border-border-mid rounded-[1px] p-1.5 shadow-[0_1px_2px_rgba(0,0,0,0.08)]" role="list">
                {features.map((f, i) => (
                    <li class:list={['py-1.5 px-2.5 flex items-center gap-2.5 text-text-secondary text-[0.85rem]', i < features.length - 1 && 'border-b border-border-dark']}>
                        <span class="text-pass font-bold text-[0.8rem]" aria-hidden="true">✓</span> {f}
                    </li>
                ))}
            </ul>
        </div>
        <div class="bg-bg-base border border-border-mid rounded-[1px] p-5 shadow-[0_2px_4px_rgba(0,0,0,0.06)]" aria-label="Ablaufdiagramm" role="figure">
            <div class="font-mono text-[0.55rem] text-text-muted text-center mb-5 tracking-[0.14em] font-medium uppercase pb-3.5 border-b border-border-dark">Ablauf: Ergebnis vor Angebot · REV-2.1</div>
            {[
              [{ bg: 'bg-bg-inset border-border-dark', icon: '▶', label: 'Deine URL' }, { bg: 'bg-red-muted border-red-dark', icon: '◉', label: 'KI-Umbau' }, { bg: 'bg-pass-muted border-pass-border', icon: '✓', label: 'Ergebnis' }],
              [{ bg: 'bg-pass-muted border-pass-border', icon: '✓', label: 'Launch' }, { bg: 'bg-red-muted border-red-dark', icon: '⚙', label: 'Feinschliff' }, { bg: 'bg-bg-inset border-border-dark', icon: '◈', label: 'Angebot' }],
            ].map((row, ri) => (
                <div class:list={['flex items-center justify-center gap-1.5 flex-wrap', ri === 0 ? 'mb-2.5' : 'mt-2.5']}>
                    {row.map((step, si) => (
                        <Fragment>
                            {si > 0 && <span class="text-steel-mid text-[0.9rem] font-bold" aria-hidden="true">{ri === 0 ? '→' : '←'}</span>}
                            <div class={`${step.bg} border rounded-[1px] p-2.5 text-center min-w-[65px] md:min-w-[75px]`}>
                                <div class="text-[0.9rem] mb-1 text-steel-light" aria-hidden="true">{step.icon}</div>
                                <div class="text-[0.45rem] md:text-[0.5rem] text-text-muted uppercase tracking-[0.06em] font-medium">{step.label}</div>
                            </div>
                        </Fragment>
                    ))}
                </div>
            ))}
        </div>
    </div>
</Section>

<!-- Prozess -->
<Section id="prozess" gray>
    <SectionHeader subtitle="Du gibst uns deine URL. Wir liefern das Ergebnis. Dann reden wir.">So <span class="text-accent-red">funktioniert's</span></SectionHeader>
    <div class="flex flex-col gap-3.5 reveal-stagger">
        <StepCard num="01" batch="PHASE-01" title="Du schickst uns drei Dinge">
            <p class="text-text-secondary mb-2 leading-relaxed text-[0.9rem] max-sm:text-[0.8rem]"><strong>Deine URL</strong>, deine Anpassungswünsche und <strong>2-3 Websites, die dir gefallen</strong> — als Orientierung für Stil und Richtung. Kein Briefing-Marathon, kein Workshop, kein 20-Seiten-Fragebogen.</p>
